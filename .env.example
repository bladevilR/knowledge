PORT=3000

# 可选。默认读取 workstation_143 知识库配置里的内网问答模型。
ARCHIVE_UI_LLM_URL=
ARCHIVE_UI_LLM_KEY=
ARCHIVE_UI_LLM_MODEL=
ARCHIVE_UI_MODEL_NAME=内网问答模型

# 可选。知识库 API 地址，用于知识图谱状态和图谱线索。
KB_API_URL=http://127.0.0.1:8001

# 可选。多个档案根目录用英文分号分隔。留空则使用 archive 插件发现的默认目录。
WORKSTATION143_ARCHIVE_ROOTS=

# 只有在用 npm start 直接服务 dist 目录时才改成 true。
SERVE_DIST=false
